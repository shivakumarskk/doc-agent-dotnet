    <Import Project="$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.6\build\Microsoft.AspNetCore.OpenApi.targets" Condition="Exists('$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.6\build\Microsoft.AspNetCore.OpenApi.targets')" />
  </ImportGroup>
</Project>